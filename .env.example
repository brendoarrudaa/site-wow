# ============================================================
# AzerothCore — Site WoW — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# Em desenvolvimento, crie também um .env.local para
# sobrescrever valores sem alterar o .env.
# ============================================================

# ── Algolia (busca) ──────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_ONLY_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_PROD_ALGOLIA=true

# ── OAuth GitHub (CMS admin /admin) ──────────────────────────
# Crie em: https://github.com/settings/developers
# Callback URL: https://<seu-dominio>/api/auth/callback
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ── Site ─────────────────────────────────────────────────────
# URL pública sem barra no final — usada pelo assertSameOrigin
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com
NEXT_PUBLIC_GA_TRACKING=
APP_NAME=Azeroth Legacy

# ── Banco de dados (AzerothCore MySQL) ───────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# ── Sessão ───────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
SESSION_SECRET=

# ── Worldserver TCP (checar se está online) ──────────────────
WORLD_HOST=127.0.0.1
WORLD_PORT=8085
SERVER_MAX_POPULATION=1000

# ── Worldserver SOAP (comandos GM pelo painel) ───────────────
# Habilite no worldserver.conf:
#   SOAP.Enabled = 1
#   SOAP.IP      = 127.0.0.1
#   SOAP.Port    = 7878
# O usuário/senha devem ser de uma conta com GM level 3+
WS_SOAP_HOST=127.0.0.1
WS_SOAP_PORT=7878
WS_SOAP_USER=
WS_SOAP_PASS=

# ── SMTP — e-mail de recuperação de senha (nodemailer) ───────
# Deixe em branco para modo dev (link impresso no console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@seu-dominio.com

# ── Resend — e-mail de verificação de cadastro ───────────────
# Obtenha sua chave em https://resend.com
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
