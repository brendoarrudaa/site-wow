# rename this file to .env and supply the values listed below
# also make sure they are available to the build tool (e.g. vercel)

NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_ONLY_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_PROD_ALGOLIA=true

# OAuth GitHub — used by the CMS admin (/admin)
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Authorization callback URL: https://<your-domain>/api/auth/callback
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Public URL of this deployment (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://site-movisul.vercel.app

NEXT_PUBLIC_GA_TRACKING=
